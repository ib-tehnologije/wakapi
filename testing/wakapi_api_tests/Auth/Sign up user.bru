meta {
  name: Sign up user
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/signup
  body: formUrlEncoded
  auth: none
}

body:form-urlencoded {
  location: {{TZ}}
  username: testuser
  email: testuser@wakapi.dev
  password: testpassword
  password_repeat: testpassword
}

script:pre-request {
  req.setMaxRedirects(0)
}

assert {
  res.status: eq 302
  res.headers['location']: eq /
}
