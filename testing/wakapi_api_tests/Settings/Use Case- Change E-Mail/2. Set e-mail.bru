meta {
  name: 2. Set e-mail
  type: http
  seq: 2
}

post {
  url: {{BASE_URL}}/settings
  body: formUrlEncoded
  auth: bearer
}

body:form-urlencoded {
  action: update_user
  location: Europe/Berlin
  email: foo@example.org
}

auth:bearer {
  token: {{WRITEUSER_TOKEN}}
}

assert {
  res.status: eq 200
  res.body: contains User updated successfully
}
