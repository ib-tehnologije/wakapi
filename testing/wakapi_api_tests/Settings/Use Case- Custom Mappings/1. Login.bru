meta {
  name: 1. Login
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/login
  body: formUrlEncoded
  auth: none
}

script:pre-request {
  // follow redirect to summary page so assertions see HTML body
  req.setMaxRedirects(3)
}

body:form-urlencoded {
  username: writeuser
  password: {{WRITEUSER_PASSWORD}}
}

assert {
  res.status: eq 200
  res.body: contains Total Time
}
