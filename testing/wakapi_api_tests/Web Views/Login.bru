meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/login
  body: formUrlEncoded
  auth: none
}

script:pre-request {
  // allow following the redirect to HTML summary page
  req.setMaxRedirects(3)
}

body:form-urlencoded {
  username: writeuser
  password: {{WRITEUSER_PASSWORD}}
}

assert {
  res.body: contains </html>
}
