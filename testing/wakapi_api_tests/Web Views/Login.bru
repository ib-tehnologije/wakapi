meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/login
  body: formUrlEncoded
  auth: none
}

script:pre-request {
  req.setMaxRedirects(0)
}

body:form-urlencoded {
  username: writeuser
  password: {{WRITEUSER_PASSWORD}}
}

assert {
  res.status: eq 302
  res.headers['location']: eq /summary
}
